# ===========================================
# ระบบต้นแบบ (Template) — ตัวอย่างตัวแปรสภาพแวดล้อม
# คัดลอกเป็น .env.local แล้วกรอกค่าจริง
# ===========================================

# --- Oracle Database ---
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=your_service
# ORACLE_SID=ORCL
ORACLE_SCHEMA=
ORACLE_CLIENT_LIB_PATH=C:\oracle\instantclient_21_18

ORACLE_USER=
ORACLE_PASSWORD=

ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10
ORACLE_POOL_INCREMENT=1

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=your_database
DB_CONNECTION_LIMIT=10

# --- LDAP (Active Directory) ---
LDAP_URL=ldaps://your-ldap-server
LDAP_BASE_DN=DC=example,DC=local
LDAP_BIND_DN=ldapuser@example.local
LDAP_BIND_PASSWORD=

# --- Session (ถ้าใช้) ---
# SESSION_SECRET=ใส่สตริงสุ่มยาวๆ
# USE_HTTPS=false
